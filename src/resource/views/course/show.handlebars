<style>
    /* Định dạng tổng thể cho trang */
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        margin: 0;
        padding: 20px;
    }

    /* Định dạng cho tiêu đề chính */
    h1 {
        color: #333;
        text-align: center;
        margin-bottom: 20px;
    }

    /* Định dạng container chứa nội dung */
    .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
